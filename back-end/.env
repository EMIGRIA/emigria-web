# Server port number (default: 3000)
PORT=

# Node environment: "development" | "production"
NODE_ENV=

# PostgreSQL connection string (Neon serverless)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=

# Google Gemini API key for structured data extraction
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# FastAPI ML service URL for fraud probability scoring
# Example: http://localhost:8000 or the deployed URL from the AI Engineer team
ML_SERVICE_URL=

# Comma-separated list of allowed CORS origins
# Example: http://localhost:5173,https://emigria.vercel.app
ALLOWED_ORIGINS=
DATABASE_URL="postgresql://placeholder:placeholder@localhost:5432/emigria"
