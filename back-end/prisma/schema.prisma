// ═══════════════════════════════════════════
// EMIGRIA — Prisma Schema
// ═══════════════════════════════════════════

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ScanLog {
  id                    String   @id @default(uuid())
  input_type            String
  country               String?
  job_title             String?
  salary                String?
  company_name          String?
  final_risk_percentage Float?
  risk_level            String
  geo_risk_level        String?
  salary_realistic      Boolean?
  created_at            DateTime @default(now())

  @@map("scan_logs")
}
